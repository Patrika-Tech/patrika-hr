<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body { background:#f5f5f0; font-family:'Segoe UI',Arial,sans-serif; }
    .test-header { background:linear-gradient(135deg,#1a1a2e,#16213e); color:#fff; padding:28px 0; }
    .test-header h2 { color:#d4af37; margin:0 0 4px; }
    .section-card { border-left:4px solid #d4af37; border-radius:8px; margin-bottom:24px; }
    .section-title { background:linear-gradient(90deg,#fffdf0,#fff); font-weight:700; font-size:1rem; padding:14px 20px; border-radius:4px 4px 0 0; color:#1a1a2e; }
    .question-block { padding:20px; border-bottom:1px solid #f0f0f0; }
    .question-block:last-child { border-bottom:none; }
    .q-text { font-weight:600; margin-bottom:12px; color:#1a1a2e; }
    .option-label { display:block; padding:10px 14px; border:1.5px solid #e0e0e0; border-radius:6px; cursor:pointer; margin-bottom:6px; transition:all .15s; }
    .option-label:hover { border-color:#d4af37; background:#fffdf0; }
    input[type=radio]:checked + .option-label { border-color:#d4af37; background:#fffdf0; font-weight:600; }
    .rating-row { display:flex; align-items:center; gap:10px; padding:10px 0; border-bottom:1px solid #f5f5f5; }
    .rating-row:last-child { border-bottom:none; }
    .rating-stmt { flex:1; font-size:.93rem; color:#333; }
    .rating-options { display:flex; gap:6px; flex-shrink:0; }
    .rating-options label { width:36px; height:36px; border:1.5px solid #ddd; border-radius:50%; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:.8rem; font-weight:600; transition:all .15s; }
    .rating-options input[type=radio]:checked + label { background:#d4af37; border-color:#d4af37; color:#fff; }
    .timer-bar { position:sticky; top:0; z-index:100; background:#1a1a2e; color:#fff; padding:8px 0; }
    .timer-pill { background:#d4af37; color:#1a1a2e; font-weight:700; padding:4px 18px; border-radius:20px; font-size:1rem; }
    .progress-indicator { font-size:.8rem; color:#aaa; }
    .btn-submit { background:#d4af37; border:none; color:#1a1a2e; font-weight:700; padding:14px 40px; font-size:1rem; border-radius:8px; }
    .btn-submit:hover { background:#c49e27; color:#1a1a2e; }
    .marks-badge { background:#1a1a2e; color:#d4af37; font-size:.75rem; padding:2px 10px; border-radius:12px; font-weight:600; }
  </style>
</head>
<body>

<!-- Timer bar -->
<div class="timer-bar">
  <div class="container d-flex justify-content-between align-items-center">
    <span class="fw-bold"><i class="bi bi-clock me-2"></i>Time Remaining: <span class="timer-pill" id="timer">15:00</span></span>
    <span class="progress-indicator" id="progressText">0 / <%= testData.sections.reduce((t,s)=>t+s.questions.length,0) %> answered</span>
  </div>
</div>

<!-- Header -->
<div class="test-header">
  <div class="container">
    <h2><%= testData.title %></h2>
    <div class="d-flex gap-3 mt-2 flex-wrap">
      <span class="badge bg-warning text-dark px-3 py-2"><i class="bi bi-clock me-1"></i><%= testData.duration %></span>
      <span class="badge bg-light text-dark px-3 py-2"><i class="bi bi-award me-1"></i>Total: <%= testData.totalMarks %> Marks</span>
      <% if (candidate) { %><span class="badge bg-secondary px-3 py-2"><i class="bi bi-person me-1"></i><%= candidate.fullName %></span><% } %>
    </div>
    <div class="mt-2 small text-white-50">Read each question carefully and answer honestly. Do not refresh the page.</div>
  </div>
</div>

<div class="container py-4" style="max-width:820px;">

  <form id="testForm">

    <% let qGlobal = 0; %>
    <% testData.sections.forEach(function(section, si) { %>

    <div class="card shadow-sm section-card">
      <div class="section-title d-flex justify-content-between align-items-center">
        <span><%= section.name %></span>
        <span class="marks-badge"><%= section.marks %> Marks</span>
      </div>
      <div class="card-body p-0">

        <% if (section.type === 'mcq') { %>
          <% section.questions.forEach(function(q, qi) { qGlobal++; %>
          <div class="question-block">
            <div class="q-text"><%= qGlobal %>. <%= q.q %></div>
            <% ['A','B','C','D'].forEach(function(opt) { %>
            <div>
              <input type="radio" class="d-none answer-radio" name="<%= section.name %>_<%= qi %>" id="<%= section.name %>_<%= qi %>_<%= opt %>" value="<%= opt %>" required>
              <label class="option-label" for="<%= section.name %>_<%= qi %>_<%= opt %>"><strong><%= opt %>.</strong> <%= q.options[opt] %></label>
            </div>
            <% }) %>
          </div>
          <% }) %>

        <% } else if (section.type === 'rating') { %>
          <div class="question-block">
            <div class="d-flex align-items-center gap-3 mb-3">
              <span class="text-muted small"><%= section.note %></span>
              <div class="d-flex gap-2 ms-auto">
                <% for(let n=1;n<=5;n++) { %><span class="text-center fw-bold" style="width:36px;font-size:.8rem;color:#d4af37;"><%= n %></span><% } %>
              </div>
            </div>
            <% section.questions.forEach(function(q, qi) { qGlobal++; %>
            <div class="rating-row">
              <span class="rating-stmt"><%= qGlobal - section.questions.length + qi + 1 %>. <%= q.q %></span>
              <div class="rating-options">
                <% for(let n=1;n<=5;n++) { %>
                <div>
                  <input type="radio" class="d-none answer-radio" name="<%= section.name %>_<%= qi %>" id="<%= section.name %>_<%= qi %>_<%= n %>" value="<%= n %>" required>
                  <label for="<%= section.name %>_<%= qi %>_<%= n %>"><%= n %></label>
                </div>
                <% } %>
              </div>
            </div>
            <% }) %>
          </div>
        <% } %>

      </div>
    </div>
    <% }) %>

    <div class="text-center my-4">
      <button type="submit" class="btn btn-submit btn-lg" id="submitBtn">
        <i class="bi bi-send-check me-2"></i>Submit Assessment
      </button>
      <div class="text-muted small mt-2">Once submitted, you cannot change your answers.</div>
    </div>

  </form>
</div>

<!-- Result modal -->
<div class="modal fade" id="resultModal" tabindex="-1" data-bs-backdrop="static">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content text-center p-4">
      <div style="font-size:3rem;">🎉</div>
      <h4 class="fw-bold mt-2">Assessment Submitted!</h4>
      <p class="text-muted">Your score: <strong id="scoreDisplay" class="fs-3 text-gold"></strong> / <%= testData.totalMarks %></p>
      <p class="text-muted small">Thank you for completing the assessment. Our team will review your results and get back to you.</p>
      <p class="text-muted small">You may close this window.</p>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
// Timer
let seconds = 15 * 60;
const timerEl = document.getElementById('timer');
const timerInterval = setInterval(() => {
  seconds--;
  const m = Math.floor(seconds / 60), s = seconds % 60;
  timerEl.textContent = `${m}:${s.toString().padStart(2,'0')}`;
  if (seconds <= 300) timerEl.style.background = '#dc3545';
  if (seconds <= 0) { clearInterval(timerInterval); submitForm(true); }
}, 1000);

// Progress tracker
const totalQ = <%= testData.sections.reduce((t,s)=>t+s.questions.length,0) %>;
document.querySelectorAll('.answer-radio').forEach(r => {
  r.addEventListener('change', () => {
    const answered = new Set([...document.querySelectorAll('.answer-radio:checked')].map(x => x.name)).size;
    document.getElementById('progressText').textContent = `${answered} / ${totalQ} answered`;
  });
});

// Submit
document.getElementById('testForm').addEventListener('submit', function(e) {
  e.preventDefault();
  submitForm(false);
});

async function submitForm(auto) {
  const btn = document.getElementById('submitBtn');
  if (btn.disabled) return;

  // Check all answered
  const answered = new Set([...document.querySelectorAll('.answer-radio:checked')].map(x => x.name)).size;
  if (!auto && answered < totalQ) {
    if (!confirm(`You have answered ${answered} of ${totalQ} questions. Submit anyway?`)) return;
  }

  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Submitting...';
  clearInterval(timerInterval);

  // Collect answers
  const data = {};
  document.querySelectorAll('.answer-radio:checked').forEach(r => { data[r.name] = r.value; });

  try {
    const r = await fetch('/test/<%= token %>/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    const d = await r.json();
    if (d.success) {
      document.getElementById('scoreDisplay').textContent = d.score;
      new bootstrap.Modal(document.getElementById('resultModal')).show();
    } else {
      alert(d.error || 'Submission failed. Please try again.');
      btn.disabled = false;
    }
  } catch(e) {
    alert('Network error. Please check your connection.');
    btn.disabled = false;
  }
}
</script>
</body>
</html>
